---
import Layout from '../layouts/Layout.astro';
import SecurityIcon from '../components/SecurityIcon.astro';
---

<Layout title="Sitio en Construcción - Protegiendo tu Seguridad">
  <div class="min-h-screen bg-gradient-to-b from-slate-950 via-blue-950 to-slate-950 overflow-hidden">
    <!-- Animated background grid -->
    <div class="fixed inset-0 pointer-events-none">
      <div class="absolute inset-0 bg-[linear-gradient(rgba(59,130,246,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(59,130,246,0.03)_1px,transparent_1px)] bg-[size:50px_50px]"></div>
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-blue-500/20 rounded-full blur-3xl opacity-20"></div>
      <div class="absolute bottom-20 right-20 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl opacity-10"></div>
    </div>

    <!-- Content container -->
    <div class="relative z-10 flex flex-col items-center justify-center min-h-screen px-4 py-20">
      <!-- Logo -->
      <div class="mb-12 animate-fade-in">
        <div class="flex items-center justify-center gap-3">
          <div class="w-16 h-16 bg-gradient-to-br from-yellow-300 to-yellow-600 rounded-lg p-3 shadow-lg shadow-yellow-500/50">
            <svg class="w-full h-full text-slate-900" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
          </div>
          <span class="text-white font-bold text-xl tracking-wider">TU LOGO</span>
        </div>
      </div>

      <!-- Main title -->
      <div class="text-center mb-16 animate-fade-in" style="animation-delay: 0.2s;">
        <h1 class="text-5xl md:text-7xl font-black text-white mb-4 tracking-tighter leading-tight">
          SITIO EN
          <br>
          <span class="bg-gradient-to-r from-blue-400 via-cyan-300 to-blue-300 bg-clip-text text-transparent">CONSTRUCCIÓN</span>
        </h1>
      </div>

      <!-- Security icons container -->
      <div class="relative w-full max-w-4xl mb-16 h-64 md:h-80 animate-fade-in" style="animation-delay: 0.4s;">
        <!-- Animated circuit lines background -->
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 800 300" preserveAspectRatio="xMidYMid slice" class="opacity-30">
          <defs>
            <pattern id="circuit" x="0" y="0" width="100" height="100" patternUnits="userSpaceOnUse">
              <path d="M0,50 L50,50 M50,0 L50,100 M100,50 L50,50" stroke="url(#lineGrad)" stroke-width="2" fill="none"/>
              <circle cx="50" cy="50" r="3" fill="rgb(59, 130, 246)"/>
            </pattern>
            <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:rgb(30, 144, 255);stop-opacity:0.5" />
              <stop offset="100%" style="stop-color:rgb(0, 200, 255);stop-opacity:0.1" />
            </linearGradient>
          </defs>
          <rect width="800" height="300" fill="url(#circuit)"/>
        </svg>

        <!-- Officer icon -->
        <div class="absolute left-0 top-1/2 -translate-y-1/2 transform scale-75 md:scale-100">
          <div class="relative w-32 h-40">
            <div class="absolute inset-0 bg-gradient-to-br from-yellow-400/30 to-yellow-600/30 rounded-lg blur-xl"></div>
            <svg class="w-full h-full" viewBox="0 0 100 120" fill="none">
              <g transform="translate(50, 10)">
                <!-- Head -->
                <circle cx="0" cy="0" r="12" fill="url(#headGrad)"/>
                <!-- Sunglasses -->
                <rect x="-14" y="-4" width="7" height="5" rx="2" fill="#1a1a1a" stroke="#fbbf24" stroke-width="1"/>
                <rect x="7" y="-4" width="7" height="5" rx="2" fill="#1a1a1a" stroke="#fbbf24" stroke-width="1"/>
                <line x1="-7" y1="-2" x2="7" y2="-2" stroke="#fbbf24" stroke-width="1"/>
              </g>
              <g transform="translate(50, 40)">
                <!-- Uniform -->
                <path d="M -15 0 L -12 25 L -6 25 L -8 15 L 8 15 L 6 25 L 12 25 L 15 0 Z" fill="url(#uniformGrad)" stroke="#fbbf24" stroke-width="1"/>
                <!-- Badges -->
                <circle cx="-4" cy="8" r="2" fill="#fbbf24"/>
                <circle cx="4" cy="8" r="2" fill="#fbbf24"/>
              </g>
              <defs>
                <linearGradient id="headGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:#fcd34d"/>
                  <stop offset="100%" style="stop-color:#f59e0b"/>
                </linearGradient>
                <linearGradient id="uniformGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:#1f2937"/>
                  <stop offset="100%" style="stop-color:#111827"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
        </div>

        <!-- Shield lock icon (center) -->
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-br from-yellow-400 to-yellow-600 rounded-2xl blur-2xl opacity-50 group-hover:opacity-75 transition-opacity duration-300"></div>
            <div class="relative bg-gradient-to-br from-yellow-300 to-yellow-600 p-8 rounded-2xl shadow-2xl">
              <svg class="w-24 h-24 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m7.93-4.93a10 10 0 1 0-14.14 14.14m14.14-14.14a10 10 0 1 1-14.14 14.14m14.14-14.14L9.26 20.26"/>
              </svg>
              <div class="absolute inset-2 rounded-xl bg-gradient-to-br from-yellow-300 to-yellow-500 opacity-20"></div>
            </div>
          </div>
        </div>

        <!-- Right side icons -->
        <div class="absolute right-0 top-1/2 -translate-y-1/2 space-y-8">
          <SecurityIcon icon="lock" delay="0.5s" />
          <SecurityIcon icon="safe" delay="0.6s" />
          <SecurityIcon icon="shield" delay="0.7s" />
        </div>
      </div>

      <!-- Animated wave visualization -->
      <div class="w-full max-w-2xl mb-12 h-20 animate-fade-in" style="animation-delay: 0.6s;">
        <svg class="w-full h-full" viewBox="0 0 1200 100" preserveAspectRatio="none">
          <defs>
            <linearGradient id="waveGrad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:rgb(30, 144, 255)"/>
              <stop offset="50%" style="stop-color:rgb(0, 200, 255)"/>
              <stop offset="100%" style="stop-color:rgb(30, 144, 255)"/>
            </linearGradient>
          </defs>
          <path d="M0,50 Q75,20 150,50 T300,50 T450,50 T600,50 T750,50 T900,50 T1050,50 T1200,50 L1200,100 L0,100 Z" fill="url(#waveGrad)" opacity="0.3"/>
          <path d="M0,60 Q100,30 200,60 T400,60 T600,60 T800,60 T1000,60 T1200,60" stroke="url(#waveGrad)" stroke-width="2" fill="none" opacity="0.6"/>
          <!-- Animated points -->
          <g opacity="0.8">
            <circle cx="150" cy="50" r="3" fill="rgb(30, 144, 255)">
              <animate attributeName="r" values="3;6;3" dur="2s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="1;0.3;1" dur="2s" repeatCount="indefinite"/>
            </circle>
            <circle cx="450" cy="50" r="3" fill="rgb(0, 200, 255)">
              <animate attributeName="r" values="3;6;3" dur="2s" begin="0.3s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="1;0.3;1" dur="2s" begin="0.3s" repeatCount="indefinite"/>
            </circle>
            <circle cx="750" cy="50" r="3" fill="rgb(30, 144, 255)">
              <animate attributeName="r" values="3;6;3" dur="2s" begin="0.6s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="1;0.3;1" dur="2s" begin="0.6s" repeatCount="indefinite"/>
            </circle>
            <circle cx="1050" cy="50" r="3" fill="rgb(0, 200, 255)">
              <animate attributeName="r" values="3;6;3" dur="2s" begin="0.9s" repeatCount="indefinite"/>
              <animate attributeName="opacity" values="1;0.3;1" dur="2s" begin="0.9s" repeatCount="indefinite"/>
            </circle>
          </g>
        </svg>
      </div>

      <!-- Footer text -->
      <div class="text-center animate-fade-in" style="animation-delay: 0.8s;">
        <p class="text-xl md:text-2xl text-gray-300 font-semibold tracking-wide">
          PROTEGIENDO SU SEGURIDAD Y DATOS
        </p>
      </div>
    </div>
  </div>

  <style>
    @keyframes fade-in {
      from {
        opacity: 0;
        transform: translateY(-20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fade-in 1s ease-out forwards;
      opacity: 0;
    }
  </style>
</Layout>
